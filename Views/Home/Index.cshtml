@{
    Layout = "~/Views/Shared/_LayoutSistema.cshtml";
}
<link rel="stylesheet" href="~/css/Dashboard.css" asp-append-version="true" />


    <div class="wrapper">
        <!-- CONTENIDO -->
        <div class="main-content w-100">
            <!-- HEADER -->
            <header class="d-flex justify-content-between align-items-center bg-dark text-white p-3">
                <h4 class="welcome-text">Bienvenido, @User.Identity.Name</h4>
                <div class="d-flex align-items-center">

                    <!-- Perfil -->
                    <div class="d-flex align-items-center me-3 user-section">
                        <img src="https://randomuser.me/api/portraits/men/75.jpg" class="rounded-circle" width="40" height="40" alt="Perfil">
                        <div class="ms-2">
                        <strong> @User.Identity.Name</strong><br />
                        <small>@ViewBag.RolUsuario</small>
                        </div>
                    </div>

                    <!-- Campana -->
                    <div class="dropdown">
                        <a class="nav-link text-white position-relative dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="lni lni-alarm fs-4"></i>

                            <!-- Badge contador -->
                            @if (ViewBag.Notificaciones != null && ViewBag.Notificaciones.Count > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    @ViewBag.Notificaciones.Count
                                </span>
                            }
                        </a>

                        <!-- Dropdown de notificaciones -->
                        <ul class="dropdown-menu dropdown-menu-end mt-2 notificaciones-dropdown"style="width: 300px; max-height: 400px; overflow-y: auto;">
                            @if (ViewBag.Notificaciones != null && ViewBag.Notificaciones.Count > 0)
                            {
                                foreach (var noti in ViewBag.Notificaciones)
                                {
                                    <li class="dropdown-item">
                                        <small class="text-muted">@noti.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</small><br />
                                        @noti.Mensaje
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                            }
                            else
                            {
                                <li class="dropdown-item text-center">No hay notificaciones</li>
                            }
                        </ul>
                    </div>


                </div> <!-- CIERRE DEL DIV de align-items-center -->
            </header>

        </div> <!-- cierre de main-content -->
    </div> <!-- cierre wrapper -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        var dropdownElementList = [].slice.call(document.querySelectorAll('.dropdown-toggle'))
        var dropdownList = dropdownElementList.map(function (dropdownToggleEl) {
            return new bootstrap.Dropdown(dropdownToggleEl)
        })
    </script>


