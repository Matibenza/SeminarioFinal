@{
    ViewData["Title"] = "Tablero";
    Layout = "_LayoutSistema";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
<link rel="stylesheet" href="~/css/Paso4.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Paso5.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Tablero.css" asp-append-version="true" />

<div class="paso0-page">
    <!-- Cabecera -->
    <div class="paso0-header">
        <h1 class="paso0-title">Tablero</h1>
    </div>
    <hr class="hr-violeta" />



    <!-- Board estilo Jira con wrapper gris -->
    <div class="board-wrapper p-3 mb-4">
        <div class="d-flex justify-content-start mb-4 toolbar-paso4">
            <button id="btnCrearTarea" class="btn btn-crear">
                <i class="bi bi-plus-lg"></i> Crear
            </button>
        </div>
        <div class="board d-flex">

            @{
                var porHacer = ViewBag.PorHacer as List<Tarea> ?? new List<Tarea>();
                var enProgreso = ViewBag.EnProgreso as List<Tarea> ?? new List<Tarea>();
                var finalizado = ViewBag.Finalizado as List<Tarea> ?? new List<Tarea>();
            }

            <!-- Columna Por Hacer -->
            <div class="board-column">
                <div class="column-header bg-info text-white">
                    Por Hacer (@porHacer.Count)
                </div>
                <div class="column-body"
                     ondragover="allowDrop(event)"
                     ondrop="dropTask(event, 'PENDIENTE')">
                    @foreach (var t in porHacer)
                    {
                        <div class="task-card"
                             draggable="true"
                             ondragstart="dragTask(event)"
                             data-id="@t.IdTarea"
                             data-priority="@t.IdPrioridad"
                             data-responsible="@t.IdResponsable">
                            <h5>@t.AccionDeMejora</h5>
                            <small>
                                @($"#FCA-{t.IdFichaTecnica:000}") · @t.Prioridad.Descripcion
                            </small>
                        </div>
                    }
                </div>
            </div>

            <!-- Columna En Progreso -->
            <div class="board-column">
                <div class="column-header bg-warning text-white">
                    En Progreso (@enProgreso.Count)
                </div>
                <div class="column-body"
                     ondragover="allowDrop(event)"
                     ondrop="dropTask(event, 'EN PROGRESO')">
                    @foreach (var t in enProgreso)
                    {
                        <div class="task-card"
                             draggable="true"
                             ondragstart="dragTask(event)"
                             data-id="@t.IdTarea"
                             data-priority="@t.IdPrioridad"
                             data-responsible="@t.IdResponsable">
                            <h5>@t.AccionDeMejora</h5>
                            <small>
                                @($"#FCA-{t.IdFichaTecnica:000}") · @t.Prioridad.Descripcion
                            </small>
                        </div>
                    }
                </div>
            </div>

            <!-- Columna Finalizado -->
            <div class="board-column">
                <div class="column-header bg-success text-white">
                    Finalizado (@finalizado.Count)
                </div>
                <div class="column-body"
                     ondragover="allowDrop(event)"
                     ondrop="dropTask(event, 'COMPLETADO')">
                    @foreach (var t in finalizado)
                    {
                        <div class="task-card"
                             draggable="true"
                             ondragstart="dragTask(event)"
                             data-id="@t.IdTarea"
                             data-priority="@t.IdPrioridad"
                             data-responsible="@t.IdResponsable">
                            <h5>@t.AccionDeMejora</h5>
                            <small>
                                @($"#FCA-{t.IdFichaTecnica:000}") · @t.Prioridad.Descripcion
                            </small>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>



@* Modal Crear Tarea (Tablero) con Choices.js *@
<div class="modal fade" id="modalNuevaTarea" tabindex="-1" aria-labelledby="modalNuevaTareaLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content bg-dark text-white">
      <div class="modal-header border-0">
        <h5 class="modal-title" id="modalNuevaTareaLabel">TAREA</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <hr class="hr-violeta" />
      <form id="antiForgeryForm"
            asp-action="CrearTarea"
            asp-controller="Tablero"
            method="post">
        @Html.AntiForgeryToken()

        @* FK a ficha, se pobla via JS cuando abras el modal *@
         

        <div class="modal-body">
          <div class="row gx-5 gy-3">

            <!-- IZQUIERDA (8 columnas) -->
            <div class="col-lg-8">
              <div class="row g-3">

                                <!-- Cliente (display only) -->
                                <div class="col-12 col-md-6">
                                    <label class="form-label">Cliente</label>
                                    <input id="txtCliente" type="text" class="form-control" disabled placeholder="Seleccione una ficha" />
                                </div>

                                <!-- Ficha Técnica (dropdown real) -->
                                <div class="col-12 col-md-6">
                                    <label class="form-label">Ficha Técnica</label>
                                    <select id="Select_IdFichaTecnica"
                                            name="IdFichaTecnica"
                                            class="form-select js-choice"
                                            data-placeholder="-- Seleccione ficha técnica --">
                                        <option value="">-- Seleccione ficha técnica --</option>
                                        @foreach (dynamic f in ViewBag.FichasTecnicas)
                                        {
                                            <option value="@f.IdFicha"
                                                    data-cliente="@f.Cliente"
                                                    data-idpieza="@f.IdPieza">
                                                @f.Texto
                                            </option>
                                        }
                                    </select>
                                </div>

                                <!-- ID Pieza (solo display) -->
                                <div class="col-12">
                                    <label class="form-label">ID Pieza</label>
                                    <input class="form-control" id="modalIdPieza" readonly />
                                </div>

                <!-- Causa (5-porqués) -->
                <div class="col-12">
                  <label class="form-label">Causa</label>
                   <select id="Select_IdCausa" name="IdCausaPasos" class="form-select js-choice">
                    <option value="">-- Seleccione causa --</option>
                    @foreach (var item in ViewBag.CausasFenomeno as List<SelectListItem>)
                    {
                      <option value="@item.Value">@item.Text</option>
                    }
                  </select>
                </div>

                <!-- Acción de Mejora -->
                <div class="col-12">
                  <label class="form-label">Acción de Mejora</label>
                  <textarea name="AccionDeMejora" class="form-control" rows="2"></textarea>
                </div>

                <!-- Descripción de la Mejora -->
                <div class="col-12">
                  <label class="form-label">Descripción de la Mejora</label>
                  <textarea name="DescripcionDeMejora" class="form-control" rows="3"></textarea>
                </div>

                <!-- Canal de Implementación -->
                <div class="col-md-6">
                  <label class="form-label">Canal de Implementación</label>
                                    <input name="CanalImplementacion" class="form-control" autocomplete="off" />
                </div>

                <!-- Lugar de Aplicación -->
                <div class="col-md-6">
                  <label class="form-label">Lugar de Aplicación</label>
                  <input name="LugarAplicacion" class="form-control"  autocomplete="off" />
                </div>

                <!-- Comentarios (display only) -->
                <div class="col-12">
                  <div class="card-section comments-section">
                    <div class="section-header d-flex justify-content-between align-items-center">
                      <div>
                        <i class="bi bi-chat-left-text"></i>
                        Comentarios
                      </div>
                      <div class="d-flex align-items-center">
                        <span class="badge bg-secondary me-2">
                          @(ViewBag.ComentariosCount ?? 0)
                        </span>
                        <i class="bi bi-plus-lg"></i>
                      </div>
                    </div>
                    <div class="comments-carousel"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- DERECHA (4 columnas) -->
            <div class="col-lg-4">
              <div class="d-grid gap-3">

                <!-- Plazos -->
                <div class="card-section">
                  <div class="section-header">
                    <i class="bi bi-clock-history"></i>
                    Plazos
                  </div>
                  <div class="row g-2">
                    <div class="col-12">
                      <label class="form-label">Fecha objetivo</label>
                      <div class="input-group date-group">
                        <input name="FechaObjetivo" type="date" class="form-control date-input" />
                        <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
                      </div>
                    </div>
                    <div class="col-12">
                      <label class="form-label">Fecha final</label>
                      <div class="input-group date-group">
                        <input name="FechaFinal" type="date" class="form-control date-input" />
                        <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Responsable -->
                <div class="card-section">
                  <div class="section-header">
                    <i class="bi bi-person-circle"></i>
                    Responsable
                  </div>
                  <select name="IdResponsable" class="form-select js-choice">
                    <option value="">-- Seleccione --</option>
                    @foreach (var u in ViewBag.EmpleadosTarea as List<SelectListItem>)
                    {
                      <option value="@u.Value">@u.Text</option>
                    }
                  </select>
                </div>

                <!-- Estado -->
                <div class="card-section">
                  <div class="section-header">
                    <i class="bi bi-hourglass-split"></i>
                    Estado
                  </div>
                    <select id="EstadoTarea" name="IdEstado" class="form-select js-choice">
                        <option value="">-- Seleccione Estado --</option>
                          @foreach (SelectListItem e in ViewBag.EstadosModal)
                                {
                                <option value="@e.Value"
                                  selected="@(e.Selected ? "selected" : "")">
                                 @e.Text
                                </option>
                                }
                    </select>
                </div>

                <!-- Prioridad -->
                <div class="card-section">
                  <div class="section-header">
                    <i class="bi bi-flag"></i>
                    Prioridad
                  </div>
                  <select id="PrioridadTarea" name="IdPrioridad" class="form-select js-choice">
                    <option value="">-- Seleccione Prioridad --</option>
                    @foreach (SelectListItem p in ViewBag.PrioridadesTarea)
                    {
                      <option value="@p.Value">@p.Text</option>
                    }
                  </select>
                </div>

                <!-- Tipo de acción -->
                <div class="card-section">
                  <div class="section-header">
                    <i class="bi bi-tools"></i>
                    Tipo de acción
                  </div>
                  <select id="TipoAccionTarea" name="IdTipoAccion" class="form-select js-choice">
                    <option value="">-- Seleccione Tipo de Acción --</option>
                    @foreach (var t in ViewBag.TiposAccionTarea as List<SelectListItem>)
                    {
                      <option value="@t.Value">@t.Text</option>
                    }
                  </select>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">
                  <button type="submit" class="btn btn-crear">Grabar</button>
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
              </div>
            </div>

          </div>
        </div>
      </form>
    </div>
  </div>
</div>


<!-- Modal Comentarios de Tarea -->
<div class="modal fade" id="modalComentariosTarea" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <form id="formComentarios"
              asp-controller="Tablero"
              asp-action="AgregarComentario"
              method="post"
              class="modal-content bg-dark text-white rounded-2xl shadow-lg">
            @Html.AntiForgeryToken()

            <div class="modal-header border-0">
                <h5 class="modal-title">Comentarios</h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar"></button>
            </div>

            <hr class="hr-violeta" />

            <div class="modal-body">
                <ul id="listaComentarios"
                    class="list-group mb-3 bg-secondary bg-opacity-10 rounded">
                    <!-- comentarios inyectados vía JS -->
                </ul>

                <textarea id="nuevoComentario"
                          name="Texto"
                          class="form-control bg-secondary bg-opacity-10 text-white"
                          rows="3"
                          placeholder="Agregar un comentario…"></textarea>

                <input type="hidden" id="comentarioTareaId" name="IdTarea" value="" />
            </div>

            <div class="modal-footer border-0">
                <button type="submit" class="btn btn-crear">
                    Comentar
                </button>
                <button type="button"
                        id="btnModificarTarea"
                        class="btn btn-crear"
                        data-bs-dismiss="modal">
                    Modificar Tarea
                </button>
                <button type="button"
                        id="btnShowDeleteTarea"
                        class="btn btn-danger"
                        data-bs-target="#modalConfirmDelete"
                        data-bs-toggle="modal">
                    Eliminar Tarea
                </button>
            </div>
        </form>
    </div>
</div>


<!-- Modal Confirmar Eliminación -->
<div class="modal fade" id="modalConfirmDelete" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white rounded-2xl shadow-lg">
            <div class="modal-header border-0">
                <h5 class="modal-title">Confirmar eliminación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <hr class="hr-violeta" />
            <div class="modal-body">
                <p>¿Estás seguro que quieres eliminar esta tarea y todos sus comentarios?</p>
            </div>
            <div class="modal-footer border-0">
                @* Guardamos el id de la tarea a eliminar *@
                <input type="hidden" id="deleteTareaId" value="" />

                <button type="button"
                        id="btnConfirmDelete"
                        class="btn btn-danger">
                    Sí, eliminar
                </button>
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>
            </div>
        </div>
    </div>
</div>



<!-- Modal Campos Incompletos (Tablero) -->
<div class="modal fade" id="modalFaltanCamposTarea" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white rounded-2xl shadow-lg">
            <div class="modal-header border-0">
                <h5 class="modal-title">Campos incompletos</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <ul id="faltanCamposList" class="list-group mb-3 bg-secondary bg-opacity-10 rounded">
                    <!-- Aquí inyectaremos, vía JS,:
                          <li class="list-group-item bg-transparent text-white">Nombre de campo requerido</li> -->
                </ul>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Aceptar</button>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    <script src="~/js/Tablero.js" asp-append-version="true"></script>
}

