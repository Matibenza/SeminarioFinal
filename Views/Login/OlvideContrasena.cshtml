@{
    ViewData["Title"] = "Recuperar Contraseþa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card login-card">
        <div class="text-center">
            <h3 class="text-black mt-3">Recuperar Contraseþa</h3>
            <p class="text-black-50">Ingrese su email para recibir un enlace de recuperaciµn.</p>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.Error as string))
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.Mensaje as string))
        {
            <div class="alert alert-success text-center">@ViewBag.Mensaje</div>
        }

        <form asp-controller="Login" asp-action="EnviarRecuperacion" method="post">
            <div class="mb-3">
                <input type="email" class="form-control login-input" id="email" name="email" placeholder="Correo electrµnico" required>
            </div>

            <button type="submit" class="btn btn-primary login-btn w-100">Enviar</button>
        </form>

        <div class="mt-3 text-center">
            <a asp-controller="Login" asp-action="Index" class="text-black-50">Volver al login</a>
        </div>
    </div>
</div>
