@{
    ViewData["Title"] = "Restablecer Contraseña";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card login-card">
        <div class="text-center">
            <h3 class="text-black mt-3">Restablecer Contraseña</h3>
            <p class="text-black-50">Ingresa y confirma tu nueva contraseña</p>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.Error as string))
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.Mensaje as string))
        {
            <div class="alert alert-success text-center">@ViewBag.Mensaje</div>
        }

        <form asp-controller="Login" asp-action="RestablecerContrasenaConfirmado" method="post" onsubmit="return validarContrasena();">
            <input type="hidden" name="token" value="@ViewBag.Token" />

            <div class="mb-3">
                <input type="password" class="form-control login-input" id="nuevaContrasena" name="nuevaContrasena" placeholder="Nueva Contraseña" required>
            </div>

            <div class="mb-3">
                <input type="password" class="form-control login-input" id="confirmarContrasena" name="confirmarContrasena" placeholder="Confirmar Contraseña" required>
            </div>

            <div id="errorMensaje" class="alert alert-danger text-center d-none">
                Las contraseñas no coinciden. Inténtalo de nuevo.
            </div>

            <button type="submit" class="btn btn-primary login-btn w-100">Restablecer Contraseña</button>
        </form>

        <div class="mt-3 text-center">
            <a asp-controller="Login" asp-action="Index" class="text-white-50">Volver al login</a>
        </div>
    </div>
</div>

<script>
    function validarContrasena() {
        var nuevaContrasena = document.getElementById("nuevaContrasena").value;
        var confirmarContrasena = document.getElementById("confirmarContrasena").value;
        var errorMensaje = document.getElementById("errorMensaje");

        if (nuevaContrasena !== confirmarContrasena) {
            errorMensaje.classList.remove("d-none");
            return false; // Evita el envío del formulario
        }

        return true; // Permite el envío si las contraseñas coinciden
    }
</script>
