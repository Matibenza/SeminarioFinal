@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center">@TempData["Error"]</div>
}

@model dynamic

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card login-card p-4">
        <div class="text-center">
            <!-- <img src="/img/logo.png" class="logo-login mb-3">  Logo (Opcional) -->
            <h3 class="text-black">Bienvenido</h3>
            <p class="text-black-50">Ingresa tus credenciales para continuar</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="mb-3">
                <input type="text" class="form-control login-input" name="username" placeholder="Usuario" required>
            </div>

            <div class="mb-3">
                <input type="password" class="form-control login-input" name="password" placeholder="Contraseña" required>
            </div>

            <button type="submit" class="btn btn-primary login-btn w-100">Ingresar</button>
        </form>

        <div class="mt-3 text-center">
            <a asp-controller="Login" asp-action="OlvideContrasena" class="text-black-50">¿Olvidaste tu contraseña?</a>
        </div>
    </div>
</div>
