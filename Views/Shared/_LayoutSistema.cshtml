@{
    Layout = null; // Asegúrate de no anidar layouts si este es el principal
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - TesisPractica</title>

    <!-- Bootstrap desde CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>


    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <!-- Lineicons -->
    <link href="https://cdn.lineicons.com/4.0/lineicons.css" rel="stylesheet" />


    <!-- Tus propios estilos -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="m-0 p-0" style="height: 100vh; overflow: hidden;">
    <!-- Usamos 100vh y overflow:hidden para que el contenedor .wrapper ocupe toda la pantalla y el scroll se maneje en .main-content -->
    <div class="wrapper d-flex" style="height: 100%;">
        <!-- SIDEBAR STICKY -->
        <aside id="sidebar"
               class="position-sticky top-0 d-flex flex-column justify-content-between text-white"
               style="width: 250px; max-height: 100vh; background-color: #141724;">
            <!-- Logo debajo -->
            <div class="d-flex justify-content-center align-items-center mt-3">
                <div class="logo m-8">
                    <img src="" alt="Logo" style="max-width: 100px;">
                </div>
            </div>

            <!-- Navegación -->
            <ul class="sidebar-nav flex-grow-1 list-unstyled ps-0 mt-3">
                <li class="sidebar-item">
                    <a href="/Home/Index" class="sidebar-link d-block px-3 py-2 text-decoration-none text-white">
                        <i class="fas fa-chart-line me-2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a asp-controller="NoConformidades" asp-action="Index" class="sidebar-link d-block px-3 py-2 text-decoration-none text-white">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <span>No conformidades</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a asp-controller="Equipos" asp-action="Index" class="sidebar-link d-block px-3 py-2 text-decoration-none text-white">
                        <i class="fas fa-users me-2"></i>
                        <span>Equipos y Roles</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a asp-controller="Tablero" asp-action="Index"
                       class="sidebar-link d-block px-3 py-2 text-decoration-none text-white">
                        <i class="fas fa-chart-line me-2"></i>
                        <span>Tablero</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="/Datos/Index" class="sidebar-link d-block px-3 py-2 text-decoration-none text-white">
                        <i class="fas fa-folder-open me-2"></i>
                        <span>Datos</span>
                    </a>
                </li>
            </ul>

            <!-- Logout -->
            <div class="logout-container d-flex justify-content-center p-3">
                <form action="/Login/Logout" method="post" class="w-100">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn d-flex align-items-center justify-content-center w-100 btn btn-danger">
                        <i class="fas fa-sign-out-alt me-2"></i>
                        <span class="d-none d-lg-inline">Cerrar sesión</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- MAIN CONTENT (scroll interno) -->
        <div class="main-content flex-grow-1 overflow-auto">
            @RenderBody()
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
