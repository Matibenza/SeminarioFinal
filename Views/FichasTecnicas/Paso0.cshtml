@model TesisPractica.Models.Paso0Contencion
@Html.ValidationSummary(true, "", new { @class = "text-danger" })
@{
    Layout = "~/Views/Shared/_LayoutSistema.cshtml";
    ViewData["Title"] = "Paso 0 - Contención";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
<link rel="stylesheet" href="~/css/Paso0.css" asp-append-version="true" />

<div class="paso0-page">
    <!-- Barra de pasos -->
    <div class="steps-bar">
        <div class="step step-active">STEP 0</div>

        <div class="step"
             style="cursor:pointer;"
             onclick="location.href='@Url.Action("Index","Paso1", new { idFicha = Model.IdFichaTecnica })'">
            STEP 1
        </div>

        <div class="step"
             style="cursor:pointer;"
             onclick="location.href='@Url.Action("Index","Paso2", new { idFicha = Model.IdFichaTecnica })'">
            STEP 2
        </div>
        <div class="step"
             style="cursor:pointer;"
             onclick="location.href='@Url.Action("Index","Paso3", new { idFicha = Model.IdFichaTecnica })'">
            STEP 3
        </div>

        <div class="step"
             style="cursor:pointer;"
             onclick="location.href='@Url.Action("Index","Paso4", new { idFicha = Model.IdFichaTecnica })'">
            STEP 4
        </div>

        <div class="step" style="cursor:pointer;"
             onclick="location.href='@Url.Action("Index","Paso5", new { idFicha = Model.IdFichaTecnica })'">
            STEP 5
        </div>
        <div class="step" style="cursor:pointer;"
             onclick="location.href='@Url.Action("Index","Paso6", new { idFicha = Model.IdFichaTecnica })'">
            STEP 6
        </div>
        <div class="step" style="cursor:pointer;"
             onclick="location.href='@Url.Action("Index","Paso7", new { idFicha = Model.IdFichaTecnica })'">
            STEP 7
        </div>
    </div>

    <!-- Contenedor principal -->
    <div class="paso0-content">
        <div class="paso0-header">
            <h2 class="paso0-title">CONTENCIÓN</h2>
            <div class="paso0-timer">
                <span>TIEMPO RESTANTE</span>
                <span class="timer-value">@ViewBag.TiempoRestante</span>
            </div>
        </div>

        <hr class="hr-violeta" />

        <form id="paso0Form" asp-action="Index"
              asp-route-idFicha="@Model.IdFichaTecnica"
              autocomplete="off"
              method="post";">
            <input type="hidden" asp-for="IdFichaTecnica" />

            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="AccionContencion">ACCIÓN DE CONTENCIÓN</label>
                <input asp-for="AccionContencion"
                       id="AccionContencion"
                       class="form-control" />
            </div>

            <div class="form-group">
                <label for="MetodoControl">MÉTODO DE CONTROL</label>
                <input asp-for="MetodoControl"
                       id="MetodoControl"
                       class="form-control" />
            </div>

            <!-- Sección de conteos -->
            <div class="counts-section">
                <div class="count-box">
                    <h4>DEPÓSITO</h4>
                    <div class="count-item sospechosa">
                        <label>CANT SOSPECHOSA</label>
                        <input asp-for="Deposito_CantSospechosa"
                               class="count-input" />
                    </div>
                    <div class="count-item controlada">
                        <label>CANT CONTROLADA</label>
                        <input asp-for="Deposito_CantControlada"
                               class="count-input" />
                    </div>
                    <div class="count-item ok">
                        <label>CANT OK</label>
                        <input asp-for="Deposito_CantOk"
                               class="count-input" />
                    </div>
                </div>

                <div class="count-box">
                    <h4>ALMACÉN</h4>
                    <div class="count-item sospechosa">
                        <label>CANT SOSPECHOSA</label>
                        <input asp-for="Almacen_CantSospechosa"
                               class="count-input" />
                    </div>
                    <div class="count-item controlada">
                        <label>CANT CONTROLADA</label>
                        <input asp-for="Almacen_CantControlada"
                               class="count-input" />
                    </div>
                    <div class="count-item ok">
                        <label>CANT OK</label>
                        <input asp-for="Almacen_CantOk"
                               class="count-input" />
                    </div>
                </div>

                <div class="count-box">
                    <h4>BORDE DE LÍNEA</h4>
                    <div class="count-item sospechosa">
                        <label>CANT SOSPECHOSA</label>
                        <input asp-for="BordeLinea_CantSospechosa"
                               class="count-input" />
                    </div>
                    <div class="count-item controlada">
                        <label>CANT CONTROLADA</label>
                        <input asp-for="BordeLinea_CantControlada"
                               class="count-input" />
                    </div>
                    <div class="count-item ok">
                        <label>CANT OK</label>
                        <input asp-for="BordeLinea_CantOk"
                               class="count-input" />
                    </div>
                </div>
            </div>

            <hr class="hr-violeta" />

            <div class="bottom-wrapper">
                <!-- Fila de fechas -->
                <div class="dates-row">
                    <div class="date-field">
                        <label for="FechaInicio">FECHA DE INICIO</label>
                        <input asp-for="FechaInicio"
                               type="date"
                               id="FechaInicio"
                               class="date-input" />
                    </div>

                    <div class="date-field">
                        <label for="FechaFin">FECHA FIN</label>
                        <input asp-for="FechaFin"
                               type="date"
                               id="FechaFin"
                               class="date-input" />
                    </div>

                    <div class="date-field">
                        <label>FECHA FIN ESTIMADA</label>

                        <!-- 1) Mostramos el texto de la fecha, formateado a dd/MM/yyyy -->
                        <div class="date-input readonly-field">
                            @(Model.FechaFinEstimada?.ToString("dd/MM/yyyy") ?? "-")
                        </div>

                        <!-- 2) Ocultamos un input que realmente envía el valor al servidor -->
                        <input asp-for="FechaFinEstimada" type="hidden" />
                    </div>
                </div>

                <!-- Fila de responsable y estado -->
            <div class="combo-row">
                <div class="combo-field">
                    <label for="Responsable">RESPONSABLE</label>
                        <select asp-for="Responsable"
                                id="Responsable"
                                class="form-select choices"
                                asp-items="ViewBag.Usuarios"
                                disabled="@(ViewBag.EsAuditor ? "disabled" : null)">
                            <option value="">-- Seleccione --</option>
                        </select>

                    <span asp-validation-for="Responsable" class="text-danger"></span>
                </div>

                <div class="combo-field">
                    <label for="IdEstado">ESTADO</label>
                        <select asp-for="IdEstado" id="IdEstado" class="form-select choices">
                            <option value="">-- Seleccione --</option>
                            @foreach (var item in (SelectList)ViewBag.Estados)
                            {
                                var isSelected = item.Value == Model.IdEstado.ToString() ? "selected" : null;
                                var isDisabled = ViewBag.EsAuditor && item.Text.ToUpper() == "TERMINADO" ? "disabled" : null;

                                <option value="@item.Value" selected="@isSelected" disabled="@isDisabled">
                                    @item.Text
                                </option>
                            }
                        </select>
                        <span asp-validation-for="IdEstado" class="text-danger"></span>
                </div>
            </div>


            </div>



            <div class="form-actions">
                <!-- Botón “Cerrar” con tu estilo secundario -->
                <a asp-action="Detalle"
                   asp-controller="FichasTecnicas"
                   asp-route-id="@Model.IdFichaTecnica"
                   class="btn-custom-secondary">
                    Cerrar
                </a>

                <!-- Botón “Guardar Paso 0” con degradado -->
                <button type="submit"
                        id="btnGuardarPaso0"
                        class="btn-custom-gradient @(ViewBag.EsPiloto || ViewBag.EsResponsable || ViewBag.EsSupervisor ? "" : "no-permitido")"
                        @(ViewBag.EsPiloto || ViewBag.EsResponsable || ViewBag.EsSupervisor ? "" : "tabindex='-1'")>
                    Guardar Paso 0
                </button>

            </div>

        </form>
    </div>
</div>

<!-- Modal de advertencia personalizada -->
<div class="modal fade paso0-modal-denegado" id="modalPermisoGuardar" tabindex="-1" aria-labelledby="modalPermisoGuardarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal-content">
            <div class="modal-header custom-modal-header">
                <h5 class="modal-title" id="modalPermisoGuardarLabel">
                    Permiso denegado
                </h5>
                <button type="button" class="btn-close custom-modal-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <hr class="hr-violeta-modal">
            <div class="modal-body custom-modal-body">
                Solo el <b>piloto</b>, el <b>responsable</b> o un <b>supervisor</b> pueden guardar los cambios.
            </div>
            <div class="modal-footer custom-modal-footer">
                <button type="button" class="btn-custom-secondary" data-bs-dismiss="modal">
                    Aceptar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de error para fechas -->
<div class="modal fade" id="modalErrorFechas" tabindex="-1" aria-labelledby="modalErrorFechasLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalErrorFechasLabel">
                    Error en las fechas
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <hr class="hr-violeta-modal">
            <div class="modal-body">
                La <b>fecha de inicio</b> debe ser menor o igual a la <b>fecha de fin</b>.<br>
                Por favor, corregí las fechas para continuar.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-custom-secondary" data-bs-dismiss="modal">
                    Aceptar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de campos obligatorios faltantes -->
<div class="modal fade" id="modalFaltanCampos" tabindex="-1" aria-labelledby="modalFaltanCamposLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal-content">
            <div class="modal-header custom-modal-header">
                <h5 class="modal-title" id="modalFaltanCamposLabel">Campos incompletos</h5>
                <button type="button" class="btn-close custom-modal-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <hr class="hr-violeta-modal">
            <div class="modal-body custom-modal-body">
                <!-- Aquí inyectaremos la lista -->
            </div>
            <div class="modal-footer custom-modal-footer">
                <button type="button" class="btn-custom-secondary" data-bs-dismiss="modal">Aceptar</button>
            </div>
        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
<script src="~/js/Paso0.js"></script> 

